# Browser-side Supabase client (safe to expose — RLS enforces access control)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-only: used exclusively by api/ingest.ts to write on a machine
# caller's behalf. Never prefix with VITE_ — must never reach the browser bundle.
SUPABASE_SERVICE_ROLE_KEY=
